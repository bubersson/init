# Ghostty Config

# shell-integration-features = ssh-terminfo to copy the terminfo entry the first time you log into a new server over SSH.
# shell-integration-features = ssh-env to configure SSH to fall back to xterm-256color.
shell-integration-features = ssh-terminfo,ssh-env

# Optionally load linux config if present (relative path to the current config)
config-file = ?config-linux
# font-size = 10

theme = "iTerm2 Tango Dark"
background = 111111
# background-blur-radius = 20
# background-opacity = 0.7

keybind = ctrl+t=new_tab
keybind = cmd+backquote=next_tab
keybind = ctrl+backquote=next_tab
keybind = cmd+shift+backquote=previous_tab
keybind = ctrl+shift+backquote=previous_tab

#### Linux

# ctrl+right_arrow is "End" from keyd (on Linux)
keybind = shift+end=unbind
keybind = shift+home=unbind
keybind = shift+page_up=unbind
keybind = shift+page_down=unbind
# TODO: ADD KEYBIND FOR CTRL+W on Linux: Test THIS!
keybind = ctrl+w=close_window

#### MacOS 

macos-titlebar-style = tabs

# cmd+q on MacOS not closing window
# Micro doesn't support Command key, so we need to remap all these to Ctrl
# Another option is to wait for ghostty to enable remapping of ctrl & command: 
# https://github.com/ghostty-org/ghostty/issues/5160
keybind = cmd+c=esc:copy
# keybind = cmd+d=text:\x04
keybind = cmd+f=text:\x06
keybind = cmd+g=text:\x07
keybind = cmd+p=text:\x10
keybind = cmd+q=text:\x11
keybind = cmd+s=text:\x13
keybind = cmd+v=text:\x16
keybind = cmd+x=text:\x18
keybind = cmd+z=text:\x1A

# Fix copy and pasting (currently copy doesn't work)
keybind = performable:ctrl+c=copy_to_clipboard
# keybind = performable:ctrl+shift+c=copy_to_clipboard
# keybind = performable:cmd+c=copy_to_clipboard
# keybind = performable:cmd+shift+c=copy_to_clipboard
keybind = performable:ctrl+v=paste_from_clipboard
# keybind = ctrl+alt+up=new_split:up

# Make sure it navigates to the end of line
keybind = cmd+left=csi:H
keybind = cmd+right=csi:F
keybind = cmd+up=csi:5~
keybind = cmd+down=csi:6~

keybind = cmd+shift+up=csi:1;6A
keybind = cmd+shift+down=csi:1;6B
keybind = cmd+shift+right=csi:1;6C
keybind = cmd+shift+left=csi:1;6D
keybind = cmd+shift+d=esc:shiftctrld

# TODO: Pick a better shortcut for the topdown terminal
keybind = global:cmd+shift+t=toggle_quick_terminal

